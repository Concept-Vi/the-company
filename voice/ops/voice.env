# voice/ops/voice.env — shared environment for the voice-trial engines + ears.
#
# Sourced by voice/ops/voice-stack (the launcher) and referenced by the systemd unit
# files in voice/ops/systemd/ (each unit has EnvironmentFile=%h/company/voice/ops/voice.env).
# Edit values here; the launcher and units both pick them up. Safe to commit — paths/ids only,
# NO secrets (STT cloud keys live in ~/company/.secrets, gitignored).
#
# NOTE on devices: post-restart the ENGINES run on the GPU (cuda). The EARS (faster-whisper)
# default to cuda too (int8_float16). For a CPU-only test now, override per-invocation:
#   COMPANY_WHISPER_DEVICE=cpu COMPANY_WHISPER_COMPUTE=int8  (do NOT bake that into this file —
#   post-restart you want the GPU path).

# ---- ports (the shared engine contract; bridge + loop both use this map) ----
COMPANY_KOKORO_PORT=4123
COMPANY_CHATTERBOX_PORT=4124
COMPANY_ORPHEUS_PORT=4125
COMPANY_COSYVOICE_PORT=4126
COMPANY_XTTS_PORT=4127
COMPANY_QWEN3TTS_PORT=4128

# ---- the bridge (the ONE Suite the loop reaches over HTTP) ----
COMPANY_BRIDGE_URL=http://127.0.0.1:8770

# ---- the shared reference clip (clone engines: chatterbox/xtts/cosyvoice) ----
# Does NOT exist yet. Generate it post-restart from Qwen3-VoiceDesign:
#   voice/ops/make_reference_clip.sh   (writes this path)
# The clone engines FAIL LOUD if this is unset/missing — that is by design (no fabricated clip).
COMPANY_VOICE_REF=/home/tim/company/voice/ref/company_voice_ref.wav

# ---- torch device for the GPU engines ----
COMPANY_TTS_DEVICE=cuda

# ---- chatterbox (:4124) ----
COMPANY_CHATTERBOX_EXAGGERATION=0.5
COMPANY_CHATTERBOX_CFG=0.5

# ---- orpheus (:4125) ----
# the CACHED model (avoid a ~6GB download); the stock default orpheus-tts-0.1-finetune-prod is not on disk.
COMPANY_ORPHEUS_MODEL=canopylabs/orpheus-3b-0.1-ft
COMPANY_ORPHEUS_VOICE=tara
COMPANY_ORPHEUS_MAXLEN=8192
COMPANY_ORPHEUS_GPU_UTIL=0.6
# graphs ON by default (fast real-time inference, pinned-resident); set =1 to force eager (instant load)
COMPANY_ORPHEUS_EAGER=0
# attention backend: FLASH_ATTN (prebuilt flash-attn 2.8.3 torch2.11/cu13 installed) — precompiled,
# no per-shape Triton JIT, no FlashInfer; the reliable backend orpheus is built for (researched 2026-06-06).
COMPANY_ORPHEUS_ATTN=FLASH_ATTN

# ---- cosyvoice (:4126) — NOT pip; a git clone the wrapper adds to sys.path ----
COMPANY_COSYVOICE_REPO=/home/tim/CosyVoice
COMPANY_COSYVOICE_DIR=/home/tim/CosyVoice/pretrained_models/CosyVoice2-0.5B
# COMPANY_COSYVOICE_INSTRUCT is optional; loop.py sends the persona voice_description per-request.
# CosyVoice imports deepspeed, which JIT-checks CUDA ops at import and FAILS LOUD if CUDA_HOME is
# unset/missing ("CUDA_HOME does not exist"). Point it at a real CUDA toolkit dir (the cu13 nvidia
# wheels: bin/nvcc + include + lib). The other engines ignore CUDA_HOME. (Fixes Tess launch 2026-06-05.)
CUDA_HOME=/home/tim/vllm-env/lib/python3.12/site-packages/nvidia/cu13

# ---- xtts (:4127) — NON-COMMERCIAL weights; TOS must be accepted non-interactively ----
COQUI_TOS_AGREED=1
COMPANY_XTTS_MODEL=tts_models/multilingual/multi-dataset/xtts_v2
COMPANY_XTTS_LANG=en

# ---- qwen3tts (:4128) — VoiceDesign; model already in HF cache ----
COMPANY_QWEN3TTS_MODEL=Qwen/Qwen3-TTS-12Hz-1.7B-VoiceDesign
COMPANY_QWEN3TTS_DEVICE=cuda:0
# attn: default sdpa (always works). Switch to flash_attention_2 only once flash-attn is built.
COMPANY_QWEN3TTS_ATTN=sdpa
COMPANY_QWEN3TTS_LANG=English

# ---- ears (faster-whisper + Silero VAD) ----
COMPANY_WHISPER_MODEL=large-v3-turbo
COMPANY_WHISPER_DEVICE=cuda
COMPANY_WHISPER_COMPUTE=int8_float16
COMPANY_WHISPER_LANG=en

# ---- venv roots (the launcher resolves each engine's python from here) ----
COMPANY_VOICE_VENVS=/home/tim/.voice-venvs
COMPANY_LOOP_VENV=/home/tim/company/.voice-venv

# Xet backend stalls on this network — force classic HTTP for all HF downloads/model loads (verified 2026-06-04)
export HF_HUB_DISABLE_XET=1
