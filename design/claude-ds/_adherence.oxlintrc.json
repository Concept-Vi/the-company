{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "app/**",
              "app/ai/**",
              "app/canvases/**",
              "app/canvases/workshop/**",
              "app/components/**",
              "app/registry/**",
              "app/services/**",
              "assets/icons/**",
              "atomicity/**",
              "axes/**",
              "axes/color/**",
              "axes/depth/**",
              "axes/fill/**",
              "axes/form/**",
              "axes/motion/**",
              "axes/size/**",
              "axes/space/**",
              "axes/symbol/**",
              "axes/texture/**",
              "components/**",
              "core/**",
              "preview/**",
              "system/**",
              "tweaks-panel.jsx",
              "ui_kits/platform/**",
              "ui_kits/platform/screens/**",
              "ui_kits/vi/**",
              "ui_kits/virtual-hub/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Sora|DM Sans|JetBrains Mono))/i]",
        "message": "Font not provided by the design system. Available: Sora, DM Sans, JetBrains Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='Avatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|alt|gold|size|key|ref|className|style|children)$/]",
        "message": "<Avatar> doesn't accept that prop. Declared props: src, alt, gold, size."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|dot|as|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, dot, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:gold|success|warning|error|comm)$/]",
        "message": "<Badge> tone must be one of 'gold' | 'success' | 'warning' | 'error' | 'comm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|pill|block|icon|as|href|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, pill, block, icon, as, href."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ink|outline|ghost|soft|comm|default)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ink' | 'outline' | 'ghost' | 'soft' | 'comm' | 'default'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|raised|interactive|pad|title|sub|footer|as|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: variant, raised, interactive, pad, title, sub, footer, as."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:soft|surface|outline|gold)$/]",
        "message": "<Card> variant must be one of 'soft' | 'surface' | 'outline' | 'gold'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute[name.name='pad'] > Literal[value!=/^(?:sm|lg)$/]",
        "message": "<Card> pad must be one of 'sm' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContainmentTree'] > JSXAttribute > JSXIdentifier[name!=/^(?:node|lod|surface|density|DiagramSolver|key|ref|className|style|children)$/]",
        "message": "<ContainmentTree> doesn't accept that prop. Declared props: node, lod, surface, density, DiagramSolver."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContainmentTree'] > JSXAttribute[name.name='lod'] > Literal[value!=/^(?:summary|pitch|full)$/]",
        "message": "<ContainmentTree> lod must be one of 'summary' | 'pitch' | 'full'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContainmentTree'] > JSXAttribute[name.name='surface'] > Literal[value!=/^(?:desktop|tablet|mobile-portrait|mobile-landscape|slide|print|web)$/]",
        "message": "<ContainmentTree> surface must be one of 'desktop' | 'tablet' | 'mobile-portrait' | 'mobile-landscape' | 'slide' | 'print' | 'web'."
      },
      {
        "selector": "JSXOpeningElement[name.name='ContainmentTree'] > JSXAttribute[name.name='density'] > Literal[value!=/^(?:compact|comfortable|spacious)$/]",
        "message": "<ContainmentTree> density must be one of 'compact' | 'comfortable' | 'spacious'."
      },
      {
        "selector": "JSXOpeningElement[name.name='DiagramSolver'] > JSXAttribute > JSXIdentifier[name!=/^(?:graph|axis|key|ref|className|style|children)$/]",
        "message": "<DiagramSolver> doesn't accept that prop. Declared props: graph, axis."
      },
      {
        "selector": "JSXOpeningElement[name.name='Glyphic'] > JSXAttribute > JSXIdentifier[name!=/^(?:form|symbol|fill|ringColor|symbolColor|texture|motion|depth|size|value|key|ref|className|style|children)$/]",
        "message": "<Glyphic> doesn't accept that prop. Declared props: form, symbol, fill, ringColor, symbolColor, texture, motion, depth, size, value."
      },
      {
        "selector": "JSXOpeningElement[name.name='Glyphic'] > JSXAttribute[name.name='form'] > Literal[value!=/^(?:none|triangle|square|pentagon|hex|septagon|octagon|diamond|circle)$/]",
        "message": "<Glyphic> form must be one of 'none' | 'triangle' | 'square' | 'pentagon' | 'hex' | 'septagon' | 'octagon' | 'diamond' | 'circle'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Glyphic'] > JSXAttribute[name.name='fill'] > Literal[value!=/^(?:none|paper|wash|tint)$/]",
        "message": "<Glyphic> fill must be one of 'none' | 'paper' | 'wash' | 'tint'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Glyphic'] > JSXAttribute[name.name='texture'] > Literal[value!=/^(?:none|hatch|dense|cross|grid|lines|vert|dots)$/]",
        "message": "<Glyphic> texture must be one of 'none' | 'hatch' | 'dense' | 'cross' | 'grid' | 'lines' | 'vert' | 'dots'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Glyphic'] > JSXAttribute[name.name='motion'] > Literal[value!=/^(?:none|breathe|pulse|bob|tilt|spin|float|glow)$/]",
        "message": "<Glyphic> motion must be one of 'none' | 'breathe' | 'pulse' | 'bob' | 'tilt' | 'spin' | 'float' | 'glow'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Glyphic'] > JSXAttribute[name.name='depth'] > Literal[value!=/^(?:flat|d1|d2|d3|d4|d5|d6|normal)$/]",
        "message": "<Glyphic> depth must be one of 'flat' | 'd1' | 'd2' | 'd3' | 'd4' | 'd5' | 'd6' | 'normal'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:as|label|hint|error|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: as, label, hint, error."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:input|textarea|select)$/]",
        "message": "<Input> as must be one of 'input' | 'textarea' | 'select'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Modal'] > JSXAttribute > JSXIdentifier[name!=/^(?:open|onClose|title|footer|key|ref|className|style|children)$/]",
        "message": "<Modal> doesn't accept that prop. Declared props: open, onClose, title, footer."
      },
      {
        "selector": "JSXOpeningElement[name.name='CVType'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|name|layer|family|runtime|defaults|slots|key|ref|className|style|children)$/]",
        "message": "<CVType> doesn't accept that prop. Declared props: id, name, layer, family, runtime, defaults, slots."
      },
      {
        "selector": "JSXOpeningElement[name.name='CVType'] > JSXAttribute[name.name='layer'] > Literal[value!=/^(?:token|atom|block|system|surface|doc|template)$/]",
        "message": "<CVType> layer must be one of 'token' | 'atom' | 'block' | 'system' | 'surface' | 'doc' | 'template'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedOption'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|key|ref|className|style|children)$/]",
        "message": "<SegmentedOption> doesn't accept that prop. Declared props: value, label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Slide'] > JSXAttribute > JSXIdentifier[name!=/^(?:archetype|content|key|ref|className|style|children)$/]",
        "message": "<Slide> doesn't accept that prop. Declared props: archetype, content."
      },
      {
        "selector": "JSXOpeningElement[name.name='StepItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|key|ref|className|style|children)$/]",
        "message": "<StepItem> doesn't accept that prop. Declared props: label."
      },
      {
        "selector": "JSXOpeningElement[name.name='Switch'] > JSXAttribute > JSXIdentifier[name!=/^(?:checked|onChange|key|ref|className|style|children)$/]",
        "message": "<Switch> doesn't accept that prop. Declared props: checked, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='TabItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:id|label|key|ref|className|style|children)$/]",
        "message": "<TabItem> doesn't accept that prop. Declared props: id, label."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
