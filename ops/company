#!/usr/bin/env python3
"""company — launcher. The console itself lives in the cli/ package next to this file.
This thin shim keeps the ~/.local/bin/company symlink valid and runs cli/app.py.
See cli/README.md (use) and cli/UPDATING.md (extend)."""
import os, sys

CLI = os.path.join(os.path.dirname(os.path.realpath(__file__)), "cli")
sys.path.insert(0, CLI)

from app import main  # noqa: E402

if __name__ == "__main__":
    main()
