#!/usr/bin/env python3
"""company — the Company's service command center.

ONE place to see what's running and start/stop/restart it. Reads the
self-describing registry (ops/services.json); drives systemd underneath.
Built for an AI operator (no humans read/write files): every command is
plain, the registry is the source of truth, nothing is hidden.

  company                 see everything + its state (same as `status`)
  company status
  company up [TARGET]      start  (no TARGET = the autostart/core set)
  company down TARGET      stop
  company restart TARGET   restart
  company logs SERVICE [-f]   tail a service's journal
  company help

TARGET is a service key (e.g. bridge), a group (core|brain|voice|models|reach),
or `all`. Examples:  company up        company restart bridge        company up voice
"""
import json, os, socket, subprocess, sys

OPS = os.path.dirname(os.path.abspath(__file__))
REG = os.path.join(OPS, "services.json")

def load():
    with open(REG) as f:
        return json.load(f)

def port_open(port, timeout=0.4):
    if not port:
        return None
    s = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
    s.settimeout(timeout)
    try:
        s.connect(("127.0.0.1", int(port)))
        return True
    except OSError:
        return False
    finally:
        s.close()

def _scope_flag(svc):
    return ["--user"] if svc["manage"]["type"] == "user-unit" else []

def unit_state(svc):
    """active | inactive | failed | not-managed (for manual)."""
    m = svc["manage"]
    if m["type"] == "manual":
        return "not-managed"
    cmd = ["systemctl"] + _scope_flag(svc) + ["is-active", m["unit"]]
    r = subprocess.run(cmd, capture_output=True, text=True)
    return r.stdout.strip() or "unknown"

def verdict(svc):
    """Combine actual-port-state + systemd-managed-state into one honest read."""
    up = port_open(svc.get("port"))
    state = unit_state(svc)
    if up is True and state == "active":
        return "RUNNING", "▶"
    if up is True and state != "active":          # running but not under systemd (drift)
        return "RUNNING (unmanaged)", "▶"
    if up is True:
        return "RUNNING", "▶"
    if state == "active":
        return "active (no port yet)", "◐"
    if state == "failed":
        return "FAILED", "✖"
    return "stopped", "·"

def resolve(reg, target):
    """target → list of service keys."""
    svcs = reg["services"]
    if target in (None, "default"):
        return [k for k, v in svcs.items() if v.get("autostart")]
    if target == "all":
        return list(svcs)
    if target in reg["groups"]:
        return [k for k, v in svcs.items() if v["group"] == target]
    if target in svcs:
        return [target]
    sys.exit(f"unknown target {target!r}. Try a service, a group ({'|'.join(reg['groups'])}), or `all`.")

def act(reg, action, keys):
    word = {"up": "start", "down": "stop", "restart": "restart"}[action]
    for k in keys:
        svc = reg["services"][k]
        m = svc["manage"]
        if m["type"] == "manual":
            print(f"  {k}: manual — no unit to {word}"); continue
        cmd = ["systemctl"] + _scope_flag(svc) + [word, m["unit"]]
        if m["type"] == "system-unit":
            cmd = ["sudo", "-n"] + cmd      # system units need root; -n so it fails fast if no passwordless sudo
        r = subprocess.run(cmd, capture_output=True, text=True)
        ok = r.returncode == 0
        print(f"  {'✓' if ok else '✗'} {word} {k} ({m['unit']})" + ("" if ok else f"  [{r.stderr.strip()[:80]}]"))

def status(reg):
    print("\n  THE COMPANY — service command center      (`company help` for commands)\n")
    for g, gdesc in reg["groups"].items():
        members = [(k, v) for k, v in reg["services"].items() if v["group"] == g]
        if not members:
            continue
        print(f"  \033[1m{g.upper()}\033[0m — {gdesc}")
        for k, v in members:
            label, sym = verdict(v)
            port = f":{v['port']}" if v.get("port") else ""
            note = f"   ⚠ {v['note']}" if v.get("note") else ""
            print(f"    {sym}  {k:<14} {label:<22} {port:<7} {v['title']}{note}")
        print()

def logs(reg, key, follow):
    if key not in reg["services"]:
        sys.exit(f"unknown service {key!r}")
    svc = reg["services"][key]
    if svc["manage"]["type"] == "manual":
        sys.exit(f"{key} is manual — no journal")
    cmd = ["journalctl"] + _scope_flag(svc) + ["-u", svc["manage"]["unit"], "-n", "60"]
    if follow:
        cmd.append("-f")
    subprocess.run(cmd)

def main():
    reg = load()
    args = sys.argv[1:]
    cmd = args[0] if args else "status"
    if cmd in ("help", "-h", "--help"):
        print(__doc__); return
    if cmd == "status":
        status(reg); return
    if cmd in ("up", "down", "restart"):
        target = args[1] if len(args) > 1 else None
        if cmd != "up" and target is None:
            sys.exit(f"`company {cmd}` needs a target (a service, a group, or `all`).")
        act(reg, cmd, resolve(reg, target))
        return
    if cmd == "logs":
        if len(args) < 2:
            sys.exit("usage: company logs SERVICE [-f]")
        logs(reg, args[1], "-f" in args)
        return
    sys.exit(f"unknown command {cmd!r}. Try `company help`.")

if __name__ == "__main__":
    main()
